CHROMA_PATH=./data/chroma
ARTICLE_DB_PATH=./data/articles.db
LOW_CORPUS_THRESHOLD=10
RAG_TOP_K=5
MAX_BLOG_POSTS=50
ALLOW_PRIVATE_URL_INGEST=false
# Google Drive: set GOOGLE_AUTH_METHOD=oauth or service_account
GOOGLE_AUTH_METHOD=oauth
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Phase 2: Author Mode Backend
# Exa: no separate app env var needed — researcher connects directly to https://mcp.exa.ai/mcp
OPENAI_API_KEY=sk-proj-...
RESEARCH_MODEL=gpt-4o-mini
DRAFT_MODEL=gpt-4o
MIN_WORD_COUNT=800
DUPLICATE_THRESHOLD=0.85
CHECKPOINT_DB_PATH=./data/bond_checkpoints.db
METADATA_DB_PATH=./data/bond_metadata.db

# Phase 3: Streaming API and Frontend
CORS_ORIGINS=["http://localhost:3000"]
